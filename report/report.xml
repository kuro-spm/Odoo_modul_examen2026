<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="report_insurance_policy" model="ir.actions.report">
        <field name="name">Insurance Policy</field>
        <field name="model">insurance.policy</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">insurance_pratssara.report_insurance_policy</field>
        <field name="report_file">insurance_pratssara.report_insurance_policy</field>
    </record>

    <template id="report_template_insurance">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="text-end">
                            <span t-esc="datetime.datetime.now()" t-options="{'widget': 'datetime'}" />
                        </div>
                        <div class="text-center">
                            <h1>INSURANCE POLICY</h1>
                        </div>
                        <table class="table table-hover">
                            <tbody>
                                <tr>
                                    <td>
                                        <strong>Number:</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.id" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <strong>Policyholder:</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.policyholder_id.display_name" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <strong>Broker:</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.broker_id.display_name" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <strong>Effective Date:</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.effective_date" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <strong>Effective Hour:</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.effective_hour" widget="float_time" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <strong>Type:</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.type" />
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <strong>Expiration Date:</strong>
                                    </td>
                                    <td>
                                        <span t-field="o.expiration_date" />
                                    </td>
                                </tr>

                                <t t-if="o.cancellation_date">
                                    <tr>
                                        <td>
                                            <strong>Cancellation Date:</strong>
                                        </td>
                                        <td>
                                            <span t-field="o.cancellation_date" />
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Cancellation Reason:</strong>
                                        </td>
                                        <td>
                                            <span t-field="o.reason_id.description" />
                                        </td>
                                    </tr>
                                </t>

                            </tbody>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>


</odoo>