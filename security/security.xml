<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        <!-- Application category for this module's groups -->
        <record id="module_category_insurance_pratssara" model="ir.module.category">
            <field name="name">insurance Prats Sara</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_insurance_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_insurance_pratssara"/>
        </record>

        <record id="group_insurance_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_insurance_pratssara"/>
        </record>

        <!-- Assign manager group to admin and OdooBot -->
        <function model="res.users" name="write">
            <value eval="[ref('base.user_admin')]"/>
            <value eval="{'groups_id': [(4, ref('insurance_pratssara.group_insurance_manager'))]}"/>
        </function>
        <function model="res.users" name="write">
            <value eval="[ref('base.user_root')]"/>
            <value eval="{'groups_id': [(4, ref('insurance_pratssara.group_insurance_manager'))]}"/>
        </function>

    </data>
</odoo>
